{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID from Firebase Auth" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "preferences": {
          "type": "object",
          "properties": {
            "selectedFont": { "type": "string" },
            "theme": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A single chat message",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "ai"] },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "text"]
    },
    "AtsResult": {
      "title": "AtsResult",
      "description": "ATS analysis result",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "score": { "type": "number" },
        "feedback": { "type": "array", "items": { "type": "string" } },
        "missingKeywords": { "type": "array", "items": { "type": "object" } },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "score"]
    },
    "Resume": {
      "title": "Resume",
      "description": "User resume data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "data": { "type": "object", "description": "Serialized ResumeData object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "data"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/resumes/{resumeId}": {
      "schema": "Resume",
      "description": "User resumes"
    }
  }
}
